# DzTherapy environment variables — copy to .env and edit.
# .env is gitignored; .env.example is committed.

# === Required (dev + prod) ===
DEBUG=True
SECRET_KEY=change-me-in-production
DATABASE_URL=postgres://dz:dz@localhost:5434/dztherapy
ALLOWED_HOSTS=localhost,127.0.0.1

# === Optional ===
# Sentry: leave empty in dev to disable. Required in production.
SENTRY_DSN=

# === Production-only changes (uncomment + fill when deploying) ===
# DEBUG=False
# SECRET_KEY=<generate a strong random secret; never commit>
# DATABASE_URL=<production Postgres connection string>
# ALLOWED_HOSTS=dztherapy.example,www.dztherapy.example
# SENTRY_DSN=<your Sentry project DSN>
