# DzTherapy environment variables — copy to .env and edit.
# .env is gitignored; .env.example is committed.

# === Required (dev + prod) ===
DEBUG=True
SECRET_KEY=change-me-in-production
DATABASE_URL=postgres://dz:dz@localhost:5434/dztherapy
ALLOWED_HOSTS=localhost,127.0.0.1

# === Optional ===
# Sentry: leave empty in dev to disable. Required in production.
SENTRY_DSN=

# Resend (transactional email). Empty = console backend in dev.
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=DzTherapy <hello@dztherapy.example>
# Absolute URL used to build email asset/CTA links. Set to the public site URL in prod.
SITE_URL=http://localhost:8000

# Daily.co (video). Empty = stub URLs in dev.
DAILY_API_KEY=
DAILY_DOMAIN=dztherapy

# Anthropic (AI intake assistant). Empty = deterministic dev fallback.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Redis (real-time messaging via Channels). Empty = in-memory channel layer
# (single-process only, fine for dev/CI). Set to redis://localhost:6385/0
# locally if you've started the docker-compose redis service.
REDIS_URL=

# === Production-only changes (uncomment + fill when deploying) ===
# DEBUG=False
# SECRET_KEY=<generate a strong random secret; never commit>
# DATABASE_URL=<production Postgres connection string>
# ALLOWED_HOSTS=dztherapy.example,www.dztherapy.example
# SENTRY_DSN=<your Sentry project DSN>
